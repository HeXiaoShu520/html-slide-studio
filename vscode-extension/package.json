{
  "name": "slide-preview",
  "displayName": "幻灯片预览",
  "description": "在 VS Code 中预览和编辑幻灯片",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:slide.preview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "slide.preview",
        "title": "Slide: 预览幻灯片"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .html",
          "command": "slide.preview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
